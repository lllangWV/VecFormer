  "serial": 11,
  "lineage": "9da8c94a-7a72-3275-5668-2bceedd9ce22",
  "outputs": {
    "compose_content": {
      "value": "services:\n  qwen3-vl-embd-8b:\n    image: vllm/vllm-openai:cu130-nightly\n    restart: unless-stopped\n    ports:\n      - \"8081:8081\"\n    deploy:\n      resources:\n        reservations:\n          devices:\n            - driver: nvidia\n              count: 1\n              capabilities: [gpu]\n    healthcheck:\n      test: [\"CMD-SHELL\", \"curl -sf http://localhost:8081/health || exit 1\"]\n      interval: 15s\n      timeout: 5s\n      retries: 60\n      start_period: 120s\n    command:\n      - RamManavalan/Qwen3-VL-Embedding-8B-FP8\n      - --served-model-name\n      - qwen3-vl-embd-8b\n      - --port\n      - \"8081\"\n      - --runner\n      - pooling\n      - --trust-remote-code\n      - --gpu-memory-utilization\n      - \"0.25\"\n      - --max-model-len\n      - \"8192\"\n      - --limit-mm-per-prompt\n      - '{\"image\":1}'\n    volumes:\n      - hf-cache:/root/.cache/huggingface\n    logging:\n      driver: awslogs\n      options:\n        awslogs-region: \"us-east-2\"\n        awslogs-group: \"/ec2-serve/embd/qwen3-vl-8b\"\n        awslogs-create-group: \"true\"\n\n  qwen3-vl-embd-2b:\n    image: vllm/vllm-openai:cu130-nightly\n    restart: unless-stopped\n    ports:\n      - \"8082:8082\"\n    deploy:\n      resources:\n        reservations:\n          devices:\n            - driver: nvidia\n              count: 1\n              capabilities: [gpu]\n    depends_on:\n      qwen3-vl-embd-8b:\n        condition: service_healthy\n    command:\n      - Qwen/Qwen3-VL-Embedding-2B\n      - --served-model-name\n      - qwen3-vl-embd-2b\n      - --port\n      - \"8082\"\n      - --runner\n      - pooling\n      - --trust-remote-code\n      - --gpu-memory-utilization\n      - \"0.15\"\n      - --max-model-len\n      - \"8192\"\n      - --limit-mm-per-prompt\n      - '{\"image\":1}'\n\n    volumes:\n      - hf-cache:/root/.cache/huggingface\n    logging:\n      driver: awslogs\n      options:\n        awslogs-region: \"us-east-2\"\n        awslogs-group: \"/ec2-serve/embd/qwen3-vl-2b\"\n        awslogs-create-group: \"true\"\n\nvolumes:\n  hf-cache:\n",
      "type": "string"
    },
    "embd_2b_url": {
      "value": "http://3.138.41.246:8082",
      "type": "string"
    },
